{
  "identifier": "default",
  "description": "Default capabilities for Codem",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "shell:allow-open",
    "shell:allow-execute",
    "shell:allow-spawn",
    "fs:default",
    "fs:read-all",
    "fs:write-all"
  ]
}
